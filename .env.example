# Redmine Semantic Search - Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These env vars override values in config.yml (if present).
# All fields below correspond 1:1 to config.yml keys.

# ---------------------------------------------------------------------------
# Redmine Connection
# ---------------------------------------------------------------------------
REDMINE_URL=https://redmine.example.com
REDMINE_API_KEY=

# ---------------------------------------------------------------------------
# Qdrant Vector Database
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6334

# ---------------------------------------------------------------------------
# Embedding Service
# ---------------------------------------------------------------------------
EMBEDDING_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Sync & Indexer
# ---------------------------------------------------------------------------
SYNC_INTERVAL=5
SYNC_BATCH_SIZE=100
RECONCILE_SCHEDULE=0 */6 * * *

# ---------------------------------------------------------------------------
# Search Server
# ---------------------------------------------------------------------------
LISTEN_ADDR=:8090
PERMISSION_CACHE_TTL=5
